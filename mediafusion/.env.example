# --- SEGURIDAD ---
# Esta contraseña bloquea el acceso a cualquier extraño a tu panel de MediaFusion
API_PASSWORD=your_secure_api_password_here

# --- RENDIMIENTO Y SCRAPERS ---
# Estos parámetros optimizan MediaFusion para P2P gratis y sin límites
IS_SCRAPPER=true
DISABLE_ALL_CATALOGS=false
DISABLE_ALL_LIVE_TV=true
MAX_PARALLEL_SCRAPING_TASKS=4
MAX_PROXIES_TO_USE=5

# --- VARIABLES REQUERIDAS DEL SISTEMA ---
CONTACT_EMAIL=your_email@example.com
HOST_URL=http://your_server_ip:8005
SECRET_KEY=your_secure_secret_key_here
